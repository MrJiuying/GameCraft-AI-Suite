# =========================
# 1. 密钥与配置文件 (最重要！防泄露)
# =========================
config.json

# =========================
# 2. Python 缓存与虚拟环境
# =========================
__pycache__/
*.py[cod]
*$py.class

# =========================
# 3. 本地数据库 (AI 记忆库)
# =========================
backend/lore_db/

# =========================
# 4. Godot 引擎缓存与临时文件
# =========================
godot_project/.godot/
*.tmp
*~

# =========================
# 5. GameCraft 动态生成的游戏资产
# (这些是 AI 实时编译出来的，不需要加入版本控制)
# =========================
godot_project/CoreSystems/blueprint.json
godot_project/CoreSystems/GameManager.gd
godot_project/CoreSystems/MainGame.tscn
# 注意：PlayerData.gd 是我们手写的核心单例，不能 Ignore！
godot_project/CoreSystems/PlayerData.gd

# =========================
# 6. 日志文件 (方便调试)
# =========================
backend/logs/

# =========================
# 7. 其他临时文件
# =========================
.DS_Store